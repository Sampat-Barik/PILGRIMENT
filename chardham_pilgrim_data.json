{
  "metadata": {
    "title": "Char Dham Yatra - Comprehensive Pilgrim Visitor Dataset",
    "description": "Annual, monthly, daily and hourly pilgrim visit data for Kedarnath, Badrinath, Gangotri, Yamunotri and related Uttarakhand pilgrimage sites. Includes historical data, real reported figures, and model-based projections.",
    "sources": [
      "Shri Badrinath Kedarnath Temple Committee (BKTC)",
      "Uttarakhand Tourism Development Board",
      "SacredYatra.com pilgrim statistics",
      "Organiser.org 2025 Char Dham records",
      "DownToEarth.org 2025 climate impact report",
      "Wikipedia - Chota Char Dham",
      "Chardham-pilgrimage-tour.com official updates"
    ],
    "notes": "Annual totals are from official BKTC and state government records. Monthly breakdowns are derived from season patterns (April–November window). Daily figures use official daily reports where available and pattern-interpolation otherwise. Hourly data uses crowd-flow modelling based on darshan window timings and known peak patterns. Projections for 2026 onwards are extrapolations based on observed 10–15% YoY growth trend.",
    "data_as_of": "May 2026",
    "season_window": "April–November (temples closed Dec–March due to snowfall)",
    "daily_cap_kedarnath": 12000,
    "daily_cap_note": "Government-mandated cap of 12,000 pilgrims per day above Gaurikund for Kedarnath (introduced 2019, relaxed in peak 2022–2025 seasons)"
  },

